# Ignore original zip files (large, already tracked elsewhere)
*.zip

# Raw backup files created by bootstrap_language.py preprocess step
*.raw.txt

# Large export files (regenerated from Bible text)
data/ctd_analysis/tokens.tsv
data/ctd_analysis/verses.tsv

# SQLite backend databases (generated, not canonical)
# Regenerate with: python scripts/backend.py migrate
data/*_backend.db

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/

# IDE
.vscode/
.idea/
logs/

# Secondary literature (PDFs and docs kept locally, not in repo)
literature/**/*.pdf
literature/**/*.doc
literature/**/*.docx
